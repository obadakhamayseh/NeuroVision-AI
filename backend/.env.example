# ==============================================================================
# NeuroVision AI REST API - Environment Configuration
# ==============================================================================
# Copy this file to .env and configure the values for your environment.

# Server Configuration
HOST=127.0.0.1
PORT=8000
DEBUG=False

# API Metadata
API_TITLE=NeuroVision AI REST API
API_VERSION=1.0.0

# CORS Settings (JSON array format)
BACKEND_CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:5173"]

# File Upload Settings
# Relative to repository root
UPLOAD_DIR=backend/uploads
# Maximum upload size in bytes (default: 15 MB)
MAX_UPLOAD_SIZE=15728640

# Model Checkpoint Directory
# Relative to repository root
MODEL_CHECKPOINT_DIR=ml/artifacts/checkpoints
MODEL_VERSION=1.0.0
